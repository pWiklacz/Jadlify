# Public Supabase configuration consumed by the SPA.
# Copy this file to `.env` (gitignored) for local development and fill in your
# project's values. In production these are injected as build-time environment
# variables on the CI runner / Azure App Service — do NOT commit real values.
#
# Both are browser-safe public values (the anon key is not a secret); the API
# enforces all authorization server-side.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
